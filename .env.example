# ninja-depth environment variables

# JWT secret for cookie-based auth (shared across ninja ecosystem)
JWT_SECRET=

# API key for external consumers (X-API-Key header)
API_KEY=

# CORS origins (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3000

# Default model: depth-anything-v2 or midas
DEFAULT_MODEL=depth-anything-v2

# Max image dimension (pixels)
MAX_IMAGE_DIM=4096

# Mesh defaults
DEFAULT_MESH_RESOLUTION=512
MAX_MESH_RESOLUTION=1024
